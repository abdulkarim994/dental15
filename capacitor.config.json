{
  "appId": "com.dental.clinic",
  "appName": "طب الأسنان الرقمي",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#060C1A",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "CapacitorSQLite": {
      "iosDatabaseLocation": "Library/CapacitorDatabase",
      "iosIsEncryption": false,
      "iosKeychainPrefix": "dental-clinic",
      "iosBiometric": {
        "biometricAuth": false
      },
      "androidIsEncryption": false,
      "androidBiometric": {
        "biometricAuth": false
      }
    }
  }
}
